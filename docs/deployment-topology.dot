digraph DeploymentTopology {
    graph [
        fontname="Helvetica,Arial,sans-serif" fontsize=11
        bgcolor="white" pad="0.3" nodesep=0.6 ranksep=0.5
        compound=true newrank=true splines=ortho
    ];
    node [
        fontname="Helvetica,Arial,sans-serif" fontsize=9
        shape=box style="rounded,filled" penwidth=1.2
    ];
    edge [
        fontname="Helvetica,Arial,sans-serif" fontsize=8
        color="#555" penwidth=1.2 arrowsize=0.8
    ];

    // === LEFT COLUMN ===

    dcm_box [
        shape=plain
        label=<<table border="2" cellborder="0" cellspacing="4" cellpadding="4" color="#CC0000" bgcolor="#FFF0F0" style="rounded">
            <tr><td colspan="4"><b>DCM Stack</b></td></tr>
            <tr>
                <td bgcolor="#EE0000"><font color="white">Gateway</font></td>
                <td bgcolor="#EE0000"><font color="white">Catalog</font></td>
                <td bgcolor="#EE0000"><font color="white">Placement</font></td>
                <td bgcolor="#EE0000"><font color="white">Policy</font></td>
            </tr>
            <tr>
                <td bgcolor="#EE0000"><font color="white">SPM</font></td>
                <td bgcolor="#E0E0E0">NATS</td>
                <td bgcolor="#E0E0E0">PostgreSQL</td>
                <td></td>
            </tr>
        </table>>
    ]

    bridge_box [
        shape=plain
        label=<<table border="2" cellborder="0" cellspacing="4" cellpadding="4" color="#6644AA" bgcolor="#F0E8FF" style="rounded">
            <tr><td colspan="3"><b>DCM-Koku Bridge</b></td></tr>
            <tr>
                <td bgcolor="#7B68EE"><font color="white">NATS consumer</font></td>
                <td bgcolor="#7B68EE"><font color="white">Koku client</font></td>
                <td bgcolor="#7B68EE"><font color="white">ID mapper</font></td>
            </tr>
            <tr>
                <td bgcolor="#7B68EE"><font color="white">Cost proxy</font></td>
                <td bgcolor="#E0E0E0">PostgreSQL</td>
                <td></td>
            </tr>
        </table>>
    ]

    koku_box [
        shape=plain
        label=<<table border="2" cellborder="0" cellspacing="4" cellpadding="4" color="#228B22" bgcolor="#F0FFF0" style="rounded">
            <tr><td colspan="3"><b>Koku Stack</b></td></tr>
            <tr>
                <td bgcolor="#2E8B57"><font color="white">Koku API</font></td>
                <td bgcolor="#2E8B57"><font color="white">Masu</font></td>
                <td bgcolor="#2E8B57"><font color="white">Workers</font></td>
            </tr>
            <tr>
                <td bgcolor="#2E8B57"><font color="white">Listener</font></td>
                <td bgcolor="#E0E0E0">PostgreSQL</td>
                <td bgcolor="#E0E0E0">Redis</td>
            </tr>
        </table>>
    ]

    hosted_box [
        shape=plain
        label=<<table border="2" cellborder="0" cellspacing="4" cellpadding="4" color="#B8860B" bgcolor="#FFFFF0" style="rounded">
            <tr><td colspan="2"><b>Hosted Clusters (HyperShift)</b></td></tr>
            <tr>
                <td port="a" bgcolor="#DAA520"><font color="white">Cluster A</font></td>
                <td port="b" bgcolor="#DAA520"><font color="white">Cluster B</font></td>
            </tr>
        </table>>
    ]

    // Left column vertical chain
    dcm_box -> bridge_box -> koku_box -> hosted_box [style=invis]

    // === RIGHT COLUMN ===

    kv_sp [label="KubeVirt VM SP" fillcolor="#4169E1" color="#2850A8" fontcolor="white" width=2 fixedsize=true]
    acm_sp [label="ACM Cluster SP" fillcolor="#4169E1" color="#2850A8" fontcolor="white" width=2 fixedsize=true]
    acm_policies [label="ACM Policies:\n• Deploy koku-metrics-operator\n  on DCM clusters\n• Configure operator with\n  Koku ingress URL" shape=note fillcolor="#FFFDE0" color="#B8860B" fontcolor="#151515"]

    // Right column vertical chain
    kv_sp -> acm_sp -> acm_policies [style=invis]

    // === ROW ALIGNMENT ===
    { rank=same; dcm_box; kv_sp; }
    { rank=same; bridge_box; acm_sp; }
    { rank=same; koku_box; acm_policies; }

    // === CROSS EDGES ===
    // ACM SP provisions hosted clusters
    acm_sp -> hosted_box [xlabel="HyperShift" color="#B8860B" fontcolor="#B8860B" penwidth=2 arrowsize=1.2]

    // Hosted clusters upload metrics to Koku
    koku_box:s -> hosted_box:n [dir=back xlabel="metrics\nuploads" style=dashed color="#228B22" fontcolor="#228B22" penwidth=2 arrowsize=1.2]
}
